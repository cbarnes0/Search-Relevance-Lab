# SITE_ADDRESS is injected from the environment (see docker-compose.prod.yml).
# A bare domain => automatic HTTPS via Let's Encrypt. ":80" => plain HTTP.
{$SITE_ADDRESS} {
	# Everything goes to the Next.js server over the internal compose network.
	# The API and datastores are never exposed — only reachable from `web`.
	reverse_proxy web:3000
}
