# Postgres
POSTGRES_USER=searchlab
POSTGRES_PASSWORD=searchlab
POSTGRES_DB=searchlab
POSTGRES_PORT=5432

# Typesense
TYPESENSE_API_KEY=local-dev-key
TYPESENSE_PORT=8108

# Qdrant
QDRANT_PORT=6333

# Embeddings (model name + dimensions are config, not hardcoded — we swap models later)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# API
API_PORT=8000

# Internal service hostnames (used inside Docker network — do not change)
POSTGRES_HOST=postgres
TYPESENSE_HOST=typesense
QDRANT_HOST=qdrant

# Web
# NOTE: the web app fetches the API server-side via API_URL (set directly in the
# compose files), so NEXT_PUBLIC_API_URL below is currently unused — kept only in
# case a future client-side call needs a browser-reachable URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
WEB_PORT=3000

# Production deploy (docker-compose.prod.yml) only.
# Your domain for automatic HTTPS, e.g. search.example.com. Leave as :80 to serve
# plain HTTP (useful for an IP-only smoke test before DNS is pointed).
SITE_ADDRESS=:80
